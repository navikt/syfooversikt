{
  "name": "syfooversikt",
  "version": "0.2.0",
  "private": true,
  "description": "Digitalisering av sykefraværsoppfølging",
  "type": "module",
  "main": "index.tsx",
  "test": "pnpm test",
  "start": "pnpm start",
  "scripts": {
    "start": "pnpm msw:update && webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js && pnpm run build:server",
    "build:server": "tsc --build ./server/tsconfig.json",
    "lint-and-typecheck": "pnpm lint && pnpm typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test --ext .ts  --ext .tsx  --ext .js  --ext .jsx",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier --write src/**/*.ts*",
    "prettier-check": "prettier --check src/**/*.ts*",
    "prettier-lint": "npm-run-all prettier lint",
    "test": "vitest run",
    "prepare": "husky install || true",
    "msw:update": "msw init public --save"
  },
