{
  "name": "syfooversikt",
  "version": "0.2.0",
  "private": true,
  "description": "Digitalisering av sykefraværsoppfølging",
  "license": "ISC",
  "author": "DigiSyfo <digisyfo@nav.no>",
  "type": "module",
  "main": "index.tsx",
  "scripts": {
    "start": "pnpm msw:update && vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc --build ./server/tsconfig.json",
    "test": "vitest run",
    "lint-and-typecheck": "pnpm lint:check && pnpm typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt:write": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "prepare": "husky install || true",
    "msw:update": "msw init . --save"
  },
  "dependencies": {
    "@grafana/faro-react": "2.8.2",
    "@grafana/faro-web-sdk": "2.8.2",
    "@grafana/faro-web-tracing": "2.8.2",
    "@navikt/aksel-icons": "8.15.0",
    "@navikt/ds-css": "8.15.0",
    "@navikt/ds-react": "8.15.0",
    "@navikt/ds-tailwind": "8.15.0",
    "@navikt/pino-logger": "5.0.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@types/express": "4.17.21",
    "@types/express-http-proxy": "1.6.7",
    "@types/react": "19.2.17",
    "@types/react-document-title": "2.0.10",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/styled-components": "5.1.34",
    "@types/umami": "2.10.1",
    "axios": "1.18.1",
    "classnames": "2.5.1",
    "core-js": "3.49.0",
    "dayjs": "1.11.21",
    "dotenv": "16.5.0",
    "dotenv-expand": "5.1.0",
    "express": "4.22.1",
    "express-http-proxy": "2.1.2",
    "helmet": "8.3.0",
    "pino": "10.3.1",
    "prom-client": "11.5.3",
    "react": "19.2.7",
    "react-app-polyfill": "0.2.2",
    "react-document-title": "2.0.3",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "regenerator-runtime": "0.14.1",
    "styled-components": "5.3.6",
    "unleash-client": "6.11.1"
  },
  "devDependencies": {
    "@styled/typescript-styled-plugin": "1.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jsdom": "21.1.7",
    "@types/node": "22.10.9",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "eslint-plugin-no-only-tests": "3.4.0",
    "husky": "8.0.3",
    "jsdom": "25.0.1",
    "less": "4.6.7",
    "lint-staged": "13.2.1",
    "msw": "2.15.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "pino-pretty": "13.1.3",
    "tailwindcss": "4.3.2",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "vite": "8.1.4",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "pnpm lint:check",
    "*.{js,ts,tsx,css,less,md}": "pnpm fmt:write"
  },
  "packageManager": "pnpm@11.1.3",
  "msw": {
    "workerDirectory": [
      ""
    ]
  }
}
