{
  "name": "syfooversikt",
  "version": "0.2.0",
  "private": true,
  "description": "Digitalisering av sykefraværsoppfølging",
  "main": "index.tsx",
  "type": "module",
  "scripts": {
    "start": "pnpm msw:update && vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc --build ./server/tsconfig.json",
    "lint-and-typecheck": "pnpm lint && pnpm typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test --ext .ts  --ext .tsx  --ext .js  --ext .jsx",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier --write src/**/*.ts*",
    "prettier-check": "prettier --check src/**/*.ts*",
    "prettier-lint": "prettier && lint",
    "test": "vitest run",
    "prepare": "husky install || true",
    "msw:update": "msw init . --save"
  },
  "author": "DigiSyfo <digisyfo@nav.no>",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@grafana/faro-react": "2.3.1",
